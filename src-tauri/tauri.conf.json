{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Oba Green",
  "version": "0.1.0",
  "identifier": "com.oba.green",
  "build": {
    "frontendDist": "https://CHANGE_ME.oba.example.com",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Oba Green",
        "width": 1100,
        "height": 700,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
