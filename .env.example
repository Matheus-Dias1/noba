# Copy this file to .env.local and fill in real values.

# Pooled Postgres connection used by the Next.js application.
DATABASE_URL=

# Direct Postgres connection used by Drizzle Kit for migrations.
# Drizzle falls back to DATABASE_URL when this is omitted.
DATABASE_URL_DIRECT=

# Secret used to sign and verify session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=
